# API Configuration
VITE_API_URL=http://localhost:8000
# Primary OSRM endpoint used by the frontend. For development with a local
# OSRM server, set the value to your local instance (example below).
# Do NOT commit your real .env file to the repository; update your local
# `.env` instead.
VITE_OSRM_SERVER=http://localhost:5050

# OpenWeatherMap API key — get yours at https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here
