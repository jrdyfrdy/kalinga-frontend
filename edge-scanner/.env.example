# Kalinga EDGE Scanner — environment variables
# Copy this to .env and fill in the values before running scanner_service.py

# Node backend base URL reachable from the EDGE device
BACKEND_URL=http://192.168.254.1:5000

# Shared secret — must match EDGE_DEVICE_API_KEY in the Node backend .env
EDGE_API_KEY=change_this_to_a_strong_secret

# Port for this Flask service
PORT=5000
